#!/bin/sh
# dsHPC post-install configuration script
# Runs automatically during R CMD INSTALL on Unix systems.
#
# Creates the DSHPC_HOME directory structure needed for:
#   - SQLite database (created at runtime by R code on first use)
#   - Artifact storage (step outputs, model weights)
#   - Runner configs (YAML files registered by other packages)
#   - Published assets (disclosure-safe results)
#
# All paths are created under DSHPC_HOME (default /srv/dshpc).
# Ownership is set to the 'rock' user if it exists (Rock/DataSHIELD).
# If the directory cannot be created (no permissions), the script
# exits gracefully and the R .onLoad() fallback handles it.

DSHPC_HOME="${DSHPC_HOME:-/srv/dshpc}"
LOG_PREFIX="[dsHPC configure]"

log_info() { echo "${LOG_PREFIX} $*"; }
log_warn() { echo "${LOG_PREFIX} WARNING: $*" >&2; }

log_info "Setting up DSHPC_HOME: ${DSHPC_HOME}"

# Create home and subdirectories
for dir in "" "/artifacts" "/runners" "/publish" "/staging"; do
  target="${DSHPC_HOME}${dir}"
  if [ ! -d "${target}" ]; then
    if mkdir -p "${target}" 2>/dev/null; then
      chmod 0777 "${target}" 2>/dev/null || true
    else
      log_warn "Cannot create ${target}. Will retry at runtime via .onLoad()."
    fi
  else
    chmod 0777 "${target}" 2>/dev/null || true
  fi
done

# Set ownership to rock user if it exists
if id rock >/dev/null 2>&1; then
  chown -R rock:rock "${DSHPC_HOME}" 2>/dev/null || true
  log_info "Ownership set to rock:rock"
fi

# Ensure R dependencies are installed (Rock only)
ROCK_LIB="/var/lib/rock/R/library"
if [ -d "${ROCK_LIB}" ]; then
  log_info "Checking R dependencies..."
  for pkg in DBI RSQLite arrow digest jsonlite processx uuid yaml; do
    Rscript --vanilla -e "
      if (!requireNamespace('${pkg}', quietly=TRUE, lib.loc='${ROCK_LIB}')) {
        cat('Installing ${pkg}...\n')
        install.packages('${pkg}', lib='${ROCK_LIB}', repos='https://cloud.r-project.org', quiet=TRUE)
      }
    " 2>/dev/null
  done
  log_info "R dependencies OK"
fi

# Verify
if [ -d "${DSHPC_HOME}" ]; then
  log_info "Setup complete: ${DSHPC_HOME}"
  ls -la "${DSHPC_HOME}/" 2>/dev/null | while read line; do log_info "  ${line}"; done
else
  log_warn "Setup incomplete. The R .onLoad() fallback will create directories at runtime."
fi

exit 0
